# Server
PORT=3000
JWT_SECRET=change-this-to-a-long-random-secret-key

# Admin key — isse naye user accounts banaye jaate hain (multi-account)
ADMIN_KEY=your-super-secret-admin-key-here

# Telegram 2FA + login alerts (SERVER ONLY — never put these in APK)
TELEGRAM_2FA_ENABLED=true
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
