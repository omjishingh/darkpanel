PORT=3100
JWT_SECRET=change-this-hostpanel-secret-key

# First admin (created on first boot if no users exist)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# Where apps live on VPS
APPS_ROOT=/var/hostpanel/apps
DATA_PATH=/var/hostpanel/data/store.json

# Public URL for webhooks
PUBLIC_URL=http://200.97.170.106:3100

# Max ZIP upload size in MB
MAX_UPLOAD_MB=50
